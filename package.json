{
  "name": "@bitfootco/skogen",
  "version": "1.0.0",
  "description": "A Tailwind and React design library built to be simple, effective & maintainable",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "styles"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/bitfootco/skogen.git"
  },
  "author": "The Bitfoot Company",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bitfootco/skogen/issues"
  },
  "homepage": "https://github.com/bitfootco/skogen#readme",
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2",
    "unrun": "^0.2.37",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "prettier": {
    "singleQuote": true,
    "plugins": [
      "@trivago/prettier-plugin-sort-imports",
      "prettier-plugin-tailwindcss"
    ],
    "importOrder": [
      "<THIRD_PARTY_MODULES>",
      "^@internal/(.*)$",
      "^[./].*(?<!\\.(c|le|sc)ss)$",
      "^[.]/[-a-zA-Z0-9_]+[.](module)[.](css|scss|less)$"
    ]
  }
}
